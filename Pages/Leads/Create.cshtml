@page
@model LeadManagement.Web.Pages.Leads.CreateModel
@{
    ViewData["Title"] = "Create lead";
}

<div class="form-page">
    <div class="page-heading mb-4">
        <a class="back-link" asp-page="/Index">← Back to dashboard</a>
        <div class="eyebrow mt-3 mb-2">Lead intake</div>
        <h1 class="display-title mb-2">Create a new lead</h1>
        <p class="text-secondary mb-0">Add contact and company details, then choose the lead's starting pipeline stage.</p>
    </div>

    <div class="content-card form-card">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Lead.FirstName" class="form-label"></label>
                    <input asp-for="Lead.FirstName" class="form-control" autocomplete="given-name" />
                    <span asp-validation-for="Lead.FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Lead.LastName" class="form-label"></label>
                    <input asp-for="Lead.LastName" class="form-control" autocomplete="family-name" />
                    <span asp-validation-for="Lead.LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Lead.Email" class="form-label"></label>
                    <input asp-for="Lead.Email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Lead.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Lead.Phone" class="form-label"></label>
                    <input asp-for="Lead.Phone" class="form-control" autocomplete="tel" />
                    <span asp-validation-for="Lead.Phone" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Lead.Company" class="form-label"></label>
                    <input asp-for="Lead.Company" class="form-control" autocomplete="organization" />
                    <span asp-validation-for="Lead.Company" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Lead.StatusId" class="form-label"></label>
                    <select asp-for="Lead.StatusId" class="form-select">
                        @foreach (var status in Model.Statuses)
                        {
                            <option value="@status.Id">@status.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Lead.StatusId" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions">
                <a class="btn btn-outline-secondary" asp-page="/Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Create lead</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

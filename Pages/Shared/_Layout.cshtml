@{
    var title = ViewData["Title"] as string ?? "Lead Management";
    var toastMessage = TempData["ToastMessage"] as string;
    var toastType = TempData["ToastType"] as string ?? "success";
    var toastClass = toastType switch
    {
        "danger" => "text-bg-danger",
        "warning" => "text-bg-warning",
        "info" => "text-bg-info",
        _ => "text-bg-success"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Professional lead management dashboard built with ASP.NET Core Razor Pages." />
    <title>@title · Lead Management</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="app-header border-bottom">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid app-shell">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index" aria-label="Lead Management dashboard">
                    <span class="brand-mark" aria-hidden="true">LM</span>
                    <span>
                        <span class="brand-title">Lead Management</span>
                        <small class="brand-subtitle d-block">Pipeline workspace</small>
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation"
                        aria-controls="mainNavigation" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavigation">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Statuses/Index">Statuses</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-light btn-sm px-3" asp-page="/Leads/Create">+ New lead</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="container-fluid app-shell py-4 py-lg-5">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer border-top">
        <div class="container-fluid app-shell d-flex flex-column flex-sm-row justify-content-between gap-2 py-3">
            <span>Lead Management Dashboard</span>
            <span>.NET 10 · Razor Pages · EF Core</span>
        </div>
    </footer>

    @if (!string.IsNullOrWhiteSpace(toastMessage))
    {
        <div class="toast-container position-fixed top-0 end-0 p-3 mt-5" aria-live="polite" aria-atomic="true">
            <div class="toast @toastClass border-0 shadow-lg" role="status" data-auto-show="true" data-bs-delay="5000">
                <div class="d-flex">
                    <div class="toast-body">@toastMessage</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
